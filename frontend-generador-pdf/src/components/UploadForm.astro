---
import BaseLayout from "../layouts/BaseLayout.astro";    
---

<div class="card shadow-sm p-4">
    <form id="formulario">
        <div class="drop-area text-center p-5 mb-3">
            <i class="fas fa-cloud-upload-alt fa-3x azul-marino mb-3"></i>
            <p class="fw-bold azul-marino">Arrastra tu archivo aquí</p>
            <p class="text-muted">o</p>
            <input type="file" name="archivo" id="archivo" hidden required />
            <button
                type="button"
                class="btn bg-navy text-white"
                onclick="document.getElementById('archivo').click()"
            >
                <i class="fas fa-file-upload"></i> Seleccionar archivo
            </button>
            <p id="nombreArchivo" class="mt-3 text-muted"></p>
        </div>

        <div class="text-center">
            <button type="submit" class="btn btn-lg bg-navy text-white">
                <i class="fas fa-gear"></i> Convertir archivo
            </button>
        </div>
    </form>

    <div id="resultado" class="mt-4 text-center"></div>
</div>


<script>
    import Swal from 'sweetalert2';

    const dropArea = document.querySelector(".drop-area");
    const fileInput = document.getElementById("archivo");
    const nombreArchivo = document.getElementById("nombreArchivo");

    dropArea.addEventListener("dragover", (e) => {
        e.preventDefault();
        dropArea.classList.add("dragover");
    });

    dropArea.addEventListener("dragleave", () => {
        dropArea.classList.remove("dragover");
    });

    dropArea.addEventListener("drop", (e) => {
        e.preventDefault();
        dropArea.classList.remove("dragover");
        fileInput.files = e.dataTransfer.files;
        nombreArchivo.textContent = fileInput.files[0].name;
    });

    fileInput.addEventListener("change", () => {
        nombreArchivo.textContent = fileInput.files[0].name;
    });

    const form = document.getElementById("formulario");

    form.addEventListener("submit", async (e) => {
        e.preventDefault();

        Swal.fire({
            title: "Convirtiendo archivo...",
            html: "Por favor espera mientras procesamos tu documento",
            allowOutsideClick: false,
            allowEscapeKey: false,
            didOpen: () => {
                Swal.showLoading();
            }
        });

        try {
            const formData = new FormData(form);

            const res = await fetch("http://localhost:3000/convertir", {
                method: "POST",
                body: formData,
            });

            const text = await res.text();
            const data = JSON.parse(text);

            if (!res.ok) {
                Swal.fire({
                    icon: "error",
                    title: "Error",
                    text: data.mensaje || "Error al convertir el archivo",
                });
                return;
            }

            const nombrePDF = data.archivo;

            await Swal.fire({
                icon: "success",
                title: "¡Archivo convertido!",
                text: "Tu documento fue convertido correctamente",
                timer: 2000,
                showConfirmButton: false,
                timerProgressBar: true,
            });

            window.location.href = `/descargar?archivo=${encodeURIComponent(nombrePDF)}`;

        } catch (err) {
            Swal.fire({
                icon: "error",
                title: "Error de conexión",
                text: err.message,
            });
        }
    });
</script>